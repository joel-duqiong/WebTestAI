# WebTestAI 环境变量配置示例
# 复制此文件为 .env 并填入真实值

# ===========================================
# LLM API 配置 (任选其一)
# ===========================================

# 阿里云百炼 (推荐，中文支持好)
LLM_PROVIDER=bailian
LLM_API_KEY=your_bailian_api_key_here
LLM_MODEL=qwen3.5-plus

# OpenAI GPT-4o
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-your_openai_key_here
# LLM_MODEL=gpt-4o

# Anthropic Claude
# LLM_PROVIDER=anthropic
# LLM_API_KEY=your_anthropic_key_here
# LLM_MODEL=claude-3-5-sonnet-20241022

# ===========================================
# 浏览器配置
# ===========================================

# Chrome 路径 (Windows)
CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Edge 路径 (Windows)
EDGE_PATH=C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe

# ChromeDriver 路径
CHROMEDRIVER_PATH=C:\Program Files\Google\Chrome\Application\chromedriver.exe

# Node.js 路径
NODE_PATH=C:\Program Files\nodejs\node.exe

# ===========================================
# 移动端测试配置 (可选)
# ===========================================

# Android ADB 路径
ANDROID_SDK_PATH=C:\Users\YOUR_USERNAME\AppData\Local\Android\Sdk

# Appium Server
APPIUM_HOST=127.0.0.1
APPIUM_PORT=4723

# ===========================================
# 云桌面配置 (可选)
# ===========================================

# AgentBay 云桌面
AGENTBAY_ACCESS_KEY=your_agentbay_access_key_here
AGENTBAY_ACCESS_SECRET=your_agentbay_access_secret_here
AGENTBAY_REGION_ID=cn-shanghai

# ===========================================
# Web 自动化配置 (可选)
# ===========================================

# Apify API Token
AUTOMATION_TOKEN=your_apify_token_here
